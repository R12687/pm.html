                        <input type="number" value={regPoint3X} onChange={(e) => setRegPoint3X(Number(e.target.value))} className="col-span-5 bg-slate-50 border border-slate-200 p-1.5 rounded font-mono text-slate-900 text-center focus:border-indigo-500 focus:outline-none" />
                        <input type="number" value={regPoint3Y} onChange={(e) => setRegPoint3Y(Number(e.target.value))} className="col-span-5 bg-slate-50 border border-slate-200 p-1.5 rounded font-mono text-slate-900 text-center focus:border-indigo-500 focus:outline-none" />
                      </div>

                      <div className="grid grid-cols-12 gap-2 items-center">
                        <div className="col-span-2 text-slate-400">4</div>
                        <input type="number" value={regPoint4X} onChange={(e) => setRegPoint4X(Number(e.target.value))} className="col-span-5 bg-slate-50 border border-slate-200 p-1.5 rounded font-mono text-slate-900 text-center focus:border-indigo-500 focus:outline-none" />
                        <input type="number" value={regPoint4Y} onChange={(e) => setRegPoint4Y(Number(e.target.value))} className="col-span-5 bg-slate-50 border border-slate-200 p-1.5 rounded font-mono text-slate-900 text-center focus:border-indigo-500 focus:outline-none" />
                      </div>

                      <div className="grid grid-cols-12 gap-2 items-center">
                        <div className="col-span-2 text-slate-400">5</div>
                        <input type="number" value={regPoint5X} onChange={(e) => setRegPoint5X(Number(e.target.value))} className="col-span-5 bg-slate-50 border border-slate-200 p-1.5 rounded font-mono text-slate-900 text-center focus:border-indigo-500 focus:outline-none" />
                        <input type="number" value={regPoint5Y} onChange={(e) => setRegPoint5Y(Number(e.target.value))} className="col-span-5 bg-slate-50 border border-slate-200 p-1.5 rounded font-mono text-slate-900 text-center focus:border-indigo-500 focus:outline-none" />
                      </div>
                    </div>
                  </div>

                  {/* Calculations & Results */}
                  <div className="lg:col-span-7 bg-white border border-slate-200 p-5 rounded-2xl shadow-sm space-y-4">
                    <h4 className="text-xs font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-2 font-sans font-sans font-sans">
                      Step-by-Step Analytical Outputs
                    </h4>

                    {regressionResults ? (
                      <div className="space-y-4 font-mono text-xs">
                        <div className="grid grid-cols-2 md:grid-cols-5 gap-2 text-center text-slate-600 bg-slate-50 p-3 rounded-xl border border-slate-200/50">
                          <div>
                            <span className="text-[10px] text-slate-400 block font-sans uppercase">ΣX</span>
                            <span className="font-bold">{regressionResults.sumX}</span>
                          </div>
                          <div>
                            <span className="text-[10px] text-slate-400 block font-sans uppercase">ΣY</span>
                            <span className="font-bold">{regressionResults.sumY}</span>
                          </div>
                          <div>
                            <span className="text-[10px] text-slate-400 block font-sans uppercase">ΣXY</span>
                            <span className="font-bold">{regressionResults.sumXY}</span>
                          </div>
                          <div>
                            <span className="text-[10px] text-slate-400 block font-sans uppercase">ΣX²</span>
                            <span className="font-bold">{regressionResults.sumX2}</span>
                          </div>
                          <div>
                            <span className="text-[10px] text-slate-400 block font-sans uppercase">ΣY²</span>
                            <span className="font-bold">{regressionResults.sumY2}</span>
                          </div>
                        </div>

                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 space-y-1">
                            <span className="text-[10px] text-slate-500 block uppercase font-bold font-sans">Slope / Variable Cost (b)</span>
                            <span className="text-lg font-black text-slate-900 block font-sans">${regressionResults.b}</span>
                            <span className="text-[10px] text-slate-400 font-sans">Increase in cost per unit increase in X.</span>
                          </div>

                          <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 space-y-1">
                            <span className="text-[10px] text-slate-500 block uppercase font-bold font-sans">Y-Intercept / Fixed Cost (a)</span>
                            <span className="text-lg font-black text-slate-900 block font-sans">${regressionResults.a}</span>
                            <span className="text-[10px] text-slate-400 font-sans">Baseline flat operational costs.</span>
                          </div>
                        </div>

                        {/* Correlation coefficients block */}
                        <div className="pt-3 border-t border-slate-100 grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div className="bg-indigo-50/50 border border-indigo-100 p-4 rounded-xl font-sans">
                            <span className="text-[10px] text-indigo-600 block uppercase font-bold font-sans">Correlation Coefficient (r)</span>
                            <span className="text-2xl font-black text-indigo-700 block mt-1 font-mono">{regressionResults.r}</span>
                            <span className="text-[10px] text-slate-500 block mt-1 font-sans">
                              {parseFloat(regressionResults.r) > 0.8 
                                ? "Very strong positive correlation" 
                                : parseFloat(regressionResults.r) > 0.5 
                                ? "Moderate positive correlation" 
                                : "Weak correlation"}
                            </span>
                          </div>

                          <div className="bg-emerald-50/50 border border-emerald-100 p-4 rounded-xl font-sans">
                            <span className="text-[10px] text-emerald-600 block uppercase font-bold font-sans">Determination Index (r²)</span>
                            <span className="text-2xl font-black text-emerald-700 block mt-1 font-mono">{(parseFloat(regressionResults.r2)*100).toFixed(1)}%</span>
                            <span className="text-[10px] text-slate-500 block mt-1 font-sans">
                              {`Proportion of cost changes directly caused by activity variations.`}
                            </span>
                          </div>
                        </div>
                      </div>
                    ) : (
                      <div className="text-slate-400 text-center py-10 font-sans">Adjust inputs to resolve regression slope parameters.</div>
                    )}
                  </div>
                </div>
              </div>
            )}

            {/* 4. Qualitative Techniques: Simulation, Focus Groups & Market Research */}
            {analyticsSubTab === 'qualitative-analytics' && (
              <div className="space-y-6 animate-fadeIn text-xs font-sans">
                <div className="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm space-y-4">
                  <h3 className="text-base font-bold text-slate-900 flex items-center gap-2">
                    <Users className="w-5 h-5 text-indigo-500" /> Qualitative & Advanced Analytical Methods
                  </h3>
                  <p className="text-slate-600 leading-relaxed text-xs">
                    While quantitative cost estimation provides baseline numbers, advanced strategic decisions rely on qualitative intelligence and predictive model simulations:
                  </p>

                  <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
                    {/* Simulation Card */}
                    <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 space-y-2">
                      <span className="font-extrabold text-slate-900 block text-sm flex items-center gap-1.5"><RotateCw className="w-4 h-4 text-indigo-600" /> Monte Carlo Simulation</span>
                      <p className="text-slate-600 leading-relaxed font-sans">
                        Simulation is a computer-based modeling technique used when multiple project variables (e.g., selling prices, unit material costs, sales volumes) are simultaneously uncertain.
                      </p>
                      <strong className="text-indigo-600 block mt-1 font-sans">Mechanism:</strong>
                      <p className="text-slate-500 font-sans font-sans">
                        The model runs thousands of iterations, substituting randomized probability distributions for each uncertain variable. This generates a comprehensive probability distribution of the final profit outcomes, highlighting the likelihood of a project making a loss.
                      </p>
                    </div>

                    {/* Focus Groups Card */}
                    <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 space-y-2 font-sans">
                      <span className="font-extrabold text-slate-900 block text-sm flex items-center gap-1.5"><Users className="w-4 h-4 text-indigo-600" /> Focus Groups</span>
                      <p className="text-slate-600 leading-relaxed">
                        A qualitative market research tool comprising small, highly structured group discussions led by a professional moderator to discuss product features, packaging, or brand perceptions.
                      </p>
                      <strong className="text-indigo-600 block mt-1">Role in Pricing:</strong>
                      <p className="text-slate-500 font-sans font-sans">
                        Focus groups provide deep behavioral insights into consumer willingness to pay, perceived product quality, and expectations. Helps identify premium features that justify a higher price point before launch.
                      </p>
                    </div>

                    {/* Market Research Card */}
                    <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 space-y-2 font-sans">
                      <span className="font-extrabold text-slate-900 block text-sm flex items-center gap-1.5"><Search className="w-4 h-4 text-indigo-600" /> Market Research</span>
                      <p className="text-slate-600 leading-relaxed font-sans">
                        The systematic gathering, recording, and analysis of qualitative and quantitative data regarding market dynamics, customer segments, and competitor behaviors.
                      </p>
                      <strong className="text-indigo-600 block mt-1">Exam Application:</strong>
                      <p className="text-slate-500 font-sans font-sans font-sans">
                        Essential to determine demand curve shifts, estimate price elasticity of demand (PED), map competitor pricing structures, and minimize decision risk before launching skimming or penetration strategies.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>
        )}

        {/* ========================================================================= */}
        {/* TAB 5: DYNAMIC PRACTICE ARENA                                             */}
        {/* ========================================================================= */}
        {activeTab === 'practice' && (
          <div className="space-y-6 animate-fadeIn">
            {/* Banner Section */}
            <section className="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm relative overflow-hidden">
              <span className="bg-indigo-50 text-indigo-600 border border-indigo-200 px-3 py-1 rounded-full text-[10px] font-extrabold tracking-wider uppercase">
                Active revision practice
              </span>
              <h2 className="text-2xl font-black text-slate-900 mt-4 tracking-tight">Dynamic Practice Arena (Non-Fixed)</h2>
              <p className="text-sm text-slate-600 mt-2 leading-relaxed font-sans">
                Test your skills with our infinite randomized question engines. Select a conceptual block, input your calculated values, and receive dynamic, step-by-step math validations instantly!
              </p>
            </section>

            {/* Selector Grid */}
            <div className="grid grid-cols-2 md:grid-cols-4 gap-2">
              <button 
                onClick={() => handleNextQuiz('roi')}
                className={`p-3 rounded-xl border text-xs font-bold transition-all text-center flex flex-col items-center gap-1.5 ${activeQuizType === 'roi' ? 'bg-indigo-500 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`}
              >
                <DollarSign className="w-4 h-4" />
                <span>ROI Pricing Practice</span>
              </button>
              <button 
                onClick={() => handleNextQuiz('ped')}
                className={`p-3 rounded-xl border text-xs font-bold transition-all text-center flex flex-col items-center gap-1.5 ${activeQuizType === 'ped' ? 'bg-indigo-500 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`}
              >
                <TrendingUp className="w-4 h-4" />
                <span>PED Elasticity Practice</span>
              </button>
              <button 
                onClick={() => handleNextQuiz('learning')}
                className={`p-3 rounded-xl border text-xs font-bold transition-all text-center flex flex-col items-center gap-1.5 ${activeQuizType === 'learning' ? 'bg-indigo-500 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`}
              >
                <Zap className="w-4 h-4" />
                <span>Learning Curve Practice</span>
              </button>
              <button 
                onClick={() => handleNextQuiz('highlow')}
                className={`p-3 rounded-xl border text-xs font-bold transition-all text-center flex flex-col items-center gap-1.5 ${activeQuizType === 'highlow' ? 'bg-indigo-500 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`}
              >
                <Calculator className="w-4 h-4" />
                <span>High-Low Separation</span>
              </button>
            </div>

            {/* Quiz Card */}
            <div className="bg-white border border-slate-200 p-6 rounded-2xl shadow-xl space-y-6">
              <div className="flex items-center justify-between border-b border-slate-100 pb-3 font-sans">
                <h3 className="text-sm font-extrabold text-slate-900 uppercase tracking-wide flex items-center">
                  <Target className="w-4 h-4 text-indigo-500 mr-1.5" /> 
                  Active Scenario Question Card
                </h3>
                <button 
                  onClick={() => handleNextQuiz(activeQuizType)}
                  className="bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center transition-all"
                >
                  <RefreshCw className="w-3 h-3 mr-1.5" /> Next Randomized Question
                </button>
              </div>

              {/* Dynamic Question Text */}
              {activeQuizType === 'roi' && (
                <div className="space-y-4">
                  <p className="text-sm text-slate-700 leading-relaxed font-sans">
                    A company holds <strong>${quizState.nca.toLocaleString()}</strong> in Non-Current Assets and <strong>${quizState.wc.toLocaleString()}</strong> in working capital. 
                    Its annual target return on investment is exactly <strong>{quizState.roi}%</strong>. 
                    Assuming a unit full cost of <strong>${quizState.fullCost.toFixed(2)}</strong> and budgeted sales volume of <strong>{quizState.units.toLocaleString()} units</strong>, 
                    what should be the Target ROI Selling Price per unit?
                  </p>
                  
                  <div className="space-y-1">
                    <label className="text-xs text-slate-500 font-bold block">Input Your Answer ($)</label>
                    <input 
                      type="number" step="0.01" value={userAnswer} onChange={(e) => setUserAnswer(e.target.value)} placeholder="e.g. 15.50"
                      className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm font-mono text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48 font-mono"
                    />
                  </div>
                </div>
              )}

              {activeQuizType === 'ped' && (
                <div className="space-y-4 font-sans font-sans">
                  <p className="text-sm text-slate-700 leading-relaxed font-sans">
                    When the price of a diagnostic kit changes from <strong>${quizState.p1}</strong> to <strong>${quizState.p2}</strong>, 
                    the market demand jumps from <strong>{quizState.q1.toLocaleString()} units</strong> to <strong>{quizState.q2.toLocaleString()} units</strong>. 
                    Calculate the Price Elasticity of Demand (PED) absolute value and classify the sensitivity.
                  </p>
                  
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="space-y-1">
                      <label className="text-xs text-slate-500 font-bold block font-sans font-sans">Absolute PED Factor</label>
                      <input 
                        type="number" step="0.01" value={userAnswer} onChange={(e) => setUserAnswer(e.target.value)} placeholder="e.g. 1.25"
                        className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm font-mono text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48 font-mono"
                      />
                    </div>
                    <div className="space-y-1 font-sans">
                      <label className="text-xs text-slate-500 font-bold block">Classification (elastic / inelastic)</label>
                      <input 
                        type="text" value={userAnswer2} onChange={(e) => setUserAnswer2(e.target.value)} placeholder="elastic or inelastic"
                        className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48 font-sans font-bold"
                      />
                    </div>
                  </div>
                </div>
              )}

              {activeQuizType === 'learning' && (
                <div className="space-y-4 font-sans font-sans">
                  <p className="text-sm text-slate-700 leading-relaxed">
                    The assembly time for the very first unit is <strong>{quizState.a} hours</strong> under an active <strong>{quizState.rate}% learning curve</strong>. 
                    What is the cumulative average time per unit and cumulative total hours to produce <strong>{quizState.x} units</strong>?
                  </p>
                  
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="space-y-1 font-sans">
                      <label className="text-xs text-slate-500 font-bold block">Cumulative Average Time per Unit (hours)</label>
                      <input 
                        type="number" step="0.01" value={userAnswer} onChange={(e) => setUserAnswer(e.target.value)} placeholder="e.g. 64.00"
                        className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm font-mono text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48"
                      />
                    </div>
                    <div className="space-y-1 font-sans">
                      <label className="text-xs text-slate-500 font-bold block">Total Cumulative hours (hours)</label>
                      <input 
                        type="number" step="0.1" value={userAnswer2} onChange={(e) => setUserAnswer2(e.target.value)} placeholder="e.g. 256.0"
                        className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm font-mono text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48"
                      />
                    </div>
                  </div>
                </div>
              )}

              {activeQuizType === 'highlow' && (
                <div className="space-y-4">
                  <p className="text-sm text-slate-700 leading-relaxed font-sans font-sans font-sans">
                    A mixed utility cost records <strong>${quizState.highC.toLocaleString()}</strong> at peak activity of <strong>{quizState.highV.toLocaleString()} units</strong>. 
                    During the slowest period of <strong>{quizState.lowV.toLocaleString()} units</strong>, costs register at <strong>${quizState.lowC.toLocaleString()}</strong>. 
                    Use the High-Low method to find the unit variable cost rate and total fixed costs.
                  </p>
                  
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="space-y-1 font-sans">
                      <label className="text-xs text-slate-500 font-bold block">Variable cost per unit ($)</label>
                      <input 
                        type="number" step="0.01" value={userAnswer} onChange={(e) => setUserAnswer(e.target.value)} placeholder="e.g. 5.00"
                        className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm font-mono text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48 font-mono"
                      />
                    </div>
                    <div className="space-y-1 font-sans">
                      <label className="text-xs text-slate-500 font-bold block">Total Fixed Costs ($)</label>
                      <input 
                        type="number" value={userAnswer2} onChange={(e) => setUserAnswer2(e.target.value)} placeholder="e.g. 15000"
                        className="bg-slate-50 border border-slate-200 px-3 py-2 rounded-xl text-sm font-mono text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none w-48 font-mono"
                      />
                    </div>
                  </div>
                </div>
              )}

              {/* Action Buttons */}
              <div className="pt-4 border-t border-slate-100 flex gap-2">
                <button 
                  onClick={handleCheckQuiz}
                  className="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-6 py-2.5 rounded-xl transition-all shadow-sm"
                >
                  Verify Calculations
                </button>
              </div>

              {/* Live dynamic feedback */}
              {quizFeedback && (
                <div className={`p-4 rounded-xl border text-xs leading-relaxed ${quizFeedback.correct ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-rose-50 text-rose-700 border-rose-200'}`}>
                  {quizFeedback.text}
                </div>
              )}
            </div>
          </div>
        )}

      </main>

      {/* --- Footer Status Banner --- */}
      <footer className="bg-white border-t border-slate-200 px-6 py-4 mt-auto">
        <div className="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-slate-400 font-medium font-sans">
          <div>
            <span>Pricing, Risk, Budgetary & Analytical Portal &copy; 2026. All Rights Reserved.</span>
          </div>
          <div className="flex items-center gap-1.5 font-sans">
            <span className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" />
            Standard Revision Environment Active
          </div>
        </div>
      </footer>
    </div>
  );
}
