import React, { useState, useMemo } from 'react';
import { 
  TrendingUp, 
  Sliders, 
  Settings, 
  Award, 
  Layers, 
  PieChart, 
  Activity, 
  Target, 
  BookOpen,
  DollarSign,
  AlertTriangle,
  Brain,
  SlidersHorizontal,
  Info,
  CheckCircle,
  HelpCircle,
  TrendingDown,
  ArrowRight,
  Book,
  XCircle,
  FileText,
  UserCheck,
  RotateCw,
  Zap,
  ChevronRight,
  RefreshCw,
  Calculator,
  Grid,
  Shield,
  Leaf,
  Users,
  Search
} from 'lucide-react';

export default function App() {
  const [activeTab, setActiveTab] = useState('pricing');
  const [pricingSubTab, setPricingSubTab] = useState('theory-costplus');
  const [riskSubTab, setRiskSubTab] = useState('theory-risk');
  const [budgetSubTab, setBudgetSubTab] = useState('theory-purposes');
  const [analyticsSubTab, setAnalyticsSubTab] = useState('theory-learning');

  // ==========================================
  // STATE: CHAPTER 7: PRICING
  // ==========================================
  const [directMaterials, setDirectMaterials] = useState(12.00);
  const [directLabor, setDirectLabor] = useState(28.00);
  const [varProdOverhead, setVarProdOverhead] = useState(3.50);
  const [varNonProdOverhead, setVarNonProdOverhead] = useState(1.50);
  const [fixedProdOverhead, setFixedProdOverhead] = useState(144000);
  const [fixedNonProdOverhead, setFixedNonProdOverhead] = useState(72000);
  const [budgetSalesUnits, setBudgetSalesUnits] = useState(18000);

  const [marginalMarkup, setMarginalMarkup] = useState(80);
  const [absorptionMarkup, setAbsorptionMarkup] = useState(25);

  const [nonCurrentAssets, setNonCurrentAssets] = useState(750000);
  const [workingCapital, setWorkingCapital] = useState(150000);
  const [targetRoi, setTargetRoi] = useState(16);

  // Economist Model Intercepts
  const [econP1, setEconP1] = useState(100.00);
  const [econQ1, setEconQ1] = useState(1000);
  const [econP2, setEconP2] = useState(80.00);
  const [econQ2, setEconQ2] = useState(2000);
  const [economistMC, setEconomistMC] = useState(30.00);

  // PED Parameters
  const [pedBasePrice, setPedBasePrice] = useState(50);
  const [pedNewPrice, setPedNewPrice] = useState(45);
  const [pedBaseQty, setPedBaseQty] = useState(1000);
  const [pedNewQty, setPedNewQty] = useState(1200);

  // ==========================================
  // STATE: CHAPTER 8: RISK & UNCERTAINTY
  // ==========================================
  const [payoffSmallCold, setPayoffSmallCold] = useState(250);
  const [payoffSmallWarm, setPayoffSmallWarm] = useState(200);
  const [payoffSmallHot, setPayoffSmallHot] = useState(150);

  const [payoffMedCold, setPayoffMedCold] = useState(200);
  const [payoffMedWarm, setPayoffMedWarm] = useState(500);
  const [payoffMedHot, setPayoffMedHot] = useState(300);

  const [payoffLargeCold, setPayoffLargeCold] = useState(100);
  const [payoffLargeWarm, setPayoffLargeWarm] = useState(300);
  const [payoffLargeHot, setPayoffLargeHot] = useState(750);

  const [probCold, setProbCold] = useState(30);
  const [probWarm, setProbWarm] = useState(50);
  const [probHot, setProbHot] = useState(20);

  // Sensitivity Variables
  const [sensitiveRevenue, setSensitiveRevenue] = useState(100000);
  const [sensitiveVarCost, setSensitiveVarCost] = useState(60000);
  const [sensitiveFixedCost, setSensitiveFixedCost] = useState(30000);

  // Decision Tree Parameters
  const [dtProbSuccess, setDtProbSuccess] = useState(65);
  const [dtA_success, setDtA_success] = useState(150000);
  const [dtA_failure, setDtA_failure] = useState(20000);
  const [dtB_success, setDtB_success] = useState(110000);
  const [dtB_failure, setDtB_failure] = useState(50000);

  // ==========================================
  // STATE: CHAPTER 9: BUDGETARY SYSTEMS
  // ==========================================
  const [budgetUnits, setBudgetUnits] = useState(10000);
  const [actualUnits, setActualUnits] = useState(12000);
  const [fixedUnitRevenue, setFixedUnitRevenue] = useState(10.00);
  const [fixedUnitVarCost, setFixedUnitVarCost] = useState(4.50);
  const [fixedBudgetOverhead, setFixedBudgetOverhead] = useState(25000);

  // ==========================================
  // STATE: CHAPTER 10: ANALYTICAL TECHNIQUES
  // ==========================================
  const [timeUnit1, setTimeUnit1] = useState(100);
  const [learnRatePct, setLearnRatePct] = useState(80);
  const [cumulativeQtyX, setCumulativeQtyX] = useState(16);

  const [highVolume, setHighVolume] = useState(4000);
  const [highCost, setHighCost] = useState(38000);
  const [lowVolume, setLowVolume] = useState(1500);
  const [lowCost, setLowCost] = useState(23000);

  // REGRESSION GRID EDITABLE STATE
  const [regPoint1X, setRegPoint1X] = useState(1000);
  const [regPoint1Y, setRegPoint1Y] = useState(15000);
  const [regPoint2X, setRegPoint2X] = useState(2000);
  const [regPoint2Y, setRegPoint2Y] = useState(22000);
  const [regPoint3X, setRegPoint3X] = useState(3000);
  const [regPoint3Y, setRegPoint3Y] = useState(31000);
  const [regPoint4X, setRegPoint4X] = useState(4000);
  const [regPoint4Y, setRegPoint4Y] = useState(38000);
  const [regPoint5X, setRegPoint5X] = useState(5000);
  const [regPoint5Y, setRegPoint5Y] = useState(47000);

  // ==========================================
  // STATE: DYNAMIC PRACTICE GENERATOR (NON-FIXED)
  // ==========================================
  const [activeQuizType, setActiveQuizType] = useState('roi'); 
  const [quizState, setQuizState] = useState(() => generateNewQuiz('roi'));
  const [userAnswer, setUserAnswer] = useState('');
  const [userAnswer2, setUserAnswer2] = useState('');
  const [quizFeedback, setQuizFeedback] = useState(null);

  // Helper to generate dynamic randomized values
  function generateNewQuiz(type) {
    if (type === 'roi') {
      const nca = Math.floor(Math.random() * 6 + 4) * 100000; 
      const wc = Math.floor(Math.random() * 11 + 5) * 10000;   
      const roi = Math.floor(Math.random() * 11 + 10);        
      const fullCost = Math.floor(Math.random() * 21 + 10);   
      const units = Math.floor(Math.random() * 5 + 1) * 10000; 
      
      const cap = nca + wc;
      const profit = cap * (roi / 100);
      const unitMarkup = profit / units;
      const targetAns = parseFloat((fullCost + unitMarkup).toFixed(2));

      return { nca, wc, roi, fullCost, units, targetAns };
    }
    if (type === 'ped') {
      const p1 = Math.floor(Math.random() * 6 + 10) * 5; 
      const p2 = p1 - 5;                                 
      const q1 = Math.floor(Math.random() * 6 + 5) * 200; 
      const q2 = Math.floor(q1 * (1.1 + Math.random() * 0.3)); 

      const priceChange = ((p2 - p1) / p1);
      const qtyChange = ((q2 - q1) / q1);
      const ped = Math.abs(qtyChange / priceChange);
      const targetAns = parseFloat(ped.toFixed(2));
      const classification = ped > 1 ? 'elastic' : 'inelastic';

      return { p1, p2, q1, q2, targetAns, classification };
    }
    if (type === 'learning') {
      const a = Math.floor(Math.random() * 11 + 8) * 10; 
      const rate = [75, 80, 85, 90][Math.floor(Math.random() * 4)];
      const x = [2, 4, 8, 16][Math.floor(Math.random() * 4)]; 

      const b = Math.log(rate / 100) / Math.log(2);
      const avgY = a * Math.pow(x, b);
      const totalTime = avgY * x;
      const targetAvg = parseFloat(avgY.toFixed(2));
      const targetTotal = parseFloat(totalTime.toFixed(1));

      return { a, rate, x, targetAvg, targetTotal };
    }
    if (type === 'highlow') {
      const lowV = Math.floor(Math.random() * 5 + 1) * 500; 
      const highV = lowV + Math.floor(Math.random() * 6 + 5) * 500; 
      const variableRate = Math.floor(Math.random() * 6 + 3); 
      const fixedBase = Math.floor(Math.random() * 5 + 1) * 5000; 

      const lowC = fixedBase + (lowV * variableRate);
      const highC = fixedBase + (highV * variableRate);

      return { lowV, highV, lowC, highC, targetVar: variableRate, targetFixed: fixedBase };
    }
  }

  const handleNextQuiz = (type) => {
    setActiveQuizType(type);
    setQuizState(generateNewQuiz(type));
    setUserAnswer('');
    setUserAnswer2('');
    setQuizFeedback(null);
  };

  const handleCheckQuiz = () => {
    if (activeQuizType === 'roi') {
      const parsedAns = parseFloat(parseFloat(userAnswer).toFixed(2));
      const isCorrect = parsedAns === quizState.targetAns;
      setQuizFeedback({
        correct: isCorrect,
        text: isCorrect 
          ? `Correct! Capital Employed = $${(quizState.nca + quizState.wc).toLocaleString()}. Required Return = $${(quizState.nca + quizState.wc).toLocaleString()} * ${quizState.roi}% = $${( (quizState.nca+quizState.wc)*(quizState.roi/100) ).toLocaleString()}. Per unit = $${( (quizState.nca+quizState.wc)*(quizState.roi/100) / quizState.units ).toFixed(2)}. Total ROI Selling Price = $${quizState.fullCost.toFixed(2)} + $${( (quizState.nca+quizState.wc)*(quizState.roi/100) / quizState.units ).toFixed(2)} = $${quizState.targetAns.toFixed(2)}.`
          : `Incorrect. Target was $${quizState.targetAns.toFixed(2)}. Verify your capital employed, required return, and markup per unit.`
      });
    }
    if (activeQuizType === 'ped') {
      const parsedAns = parseFloat(parseFloat(userAnswer).toFixed(2));
      const classAns = userAnswer2.trim().toLowerCase();
      const isCorrectValue = Math.abs(parsedAns - quizState.targetAns) <= 0.05;
      const isCorrectClass = classAns === quizState.classification;

      setQuizFeedback({
        correct: isCorrectValue && isCorrectClass,
        text: isCorrectValue && isCorrectClass
          ? `Superb! Price change: ${(((quizState.p2 - quizState.p1)/quizState.p1)*100).toFixed(1)}%. Quantity change: ${(((quizState.q2 - quizState.q1)/quizState.q1)*100).toFixed(1)}%. PED = ${quizState.targetAns}. This is Classified as ${quizState.classification.toUpperCase()}.`
          : `Almost! Correct PED value: ${quizState.targetAns} (${quizState.classification.toUpperCase()}). Check your percentages.`
      });
    }
    if (activeQuizType === 'learning') {
      const parsedAvg = parseFloat(parseFloat(userAnswer).toFixed(2));
      const parsedTot = parseFloat(parseFloat(userAnswer2).toFixed(1));
      const isCorrectAvg = Math.abs(parsedAvg - quizState.targetAvg) <= 0.1;
      const isCorrectTot = Math.abs(parsedTot - quizState.targetTotal) <= 1.0;

      setQuizFeedback({
        correct: isCorrectAvg && isCorrectTot,
        text: isCorrectAvg && isCorrectTot
          ? `Perfect! Cumulative Avg Time = ${quizState.targetAvg} hrs. Total Cumulative Time = ${quizState.targetTotal} hrs.`
          : `Check your calculations. Correct Cumulative Average: ${quizState.targetAvg} hrs, Correct Total Time: ${quizState.targetTotal} hrs.`
      });
    }
    if (activeQuizType === 'highlow') {
      const parsedVar = parseFloat(parseFloat(userAnswer).toFixed(2));
      const parsedFixed = parseInt(userAnswer2);
      const isCorrectVar = parsedVar === quizState.targetVar;
      const isCorrectFixed = parsedFixed === quizState.targetFixed;

      setQuizFeedback({
        correct: isCorrectVar && isCorrectFixed,
        text: isCorrectVar && isCorrectFixed
          ? `Correct! Variable cost = $${quizState.targetVar}/unit. Total Fixed Costs = $${quizState.targetFixed.toLocaleString()}.`
          : `Let's practice again. Variable cost = $${quizState.targetVar}/unit, Fixed Costs = $${quizState.targetFixed.toLocaleString()}.`
      });
    }
  };

  // ==========================================
  // SYSTEM-WIDE CALCULATIONS: MASTER OBJECT
  // ==========================================

  // Pricing Calculations
  const pricingCalculations = useMemo(() => {
    const fixedProdPerUnit = fixedProdOverhead / budgetSalesUnits;
    const fixedNonProdPerUnit = fixedNonProdOverhead / budgetSalesUnits;

    // Full Cost Stack
    const unitFullCost = directMaterials + directLabor + varProdOverhead + fixedProdPerUnit + varNonProdOverhead + fixedNonProdPerUnit;
    const fullCostMarkupVal = unitFullCost * (absorptionMarkup / 100);
    const fullCostSellingPrice = unitFullCost + fullCostMarkupVal;

    // Variable Cost Stack
    const unitVarCost = directMaterials + directLabor + varProdOverhead + varNonProdOverhead;
    const varCostMarkupVal = unitVarCost * (marginalMarkup / 100);
    const varCostSellingPrice = unitVarCost + varCostMarkupVal;

    // ROI Base
    const totalCapitalEmployed = nonCurrentAssets + workingCapital;
    const requiredProfitAnnual = totalCapitalEmployed * (targetRoi / 100);
    const requiredProfitPerUnit = requiredProfitAnnual / budgetSalesUnits;
    const roiSellingPrice = unitFullCost + requiredProfitPerUnit;

    return {
      fixedProdPerUnit,
      fixedNonProdPerUnit,
      unitFullCost,
      fullCostSellingPrice,
      unitVarCost,
      varCostSellingPrice,
      totalCapitalEmployed,
      requiredProfitAnnual,
      requiredProfitPerUnit,
      roiSellingPrice
    };
  }, [
    directMaterials, directLabor, varProdOverhead, varNonProdOverhead,
    fixedProdOverhead, fixedNonProdOverhead, budgetSalesUnits, absorptionMarkup,
    marginalMarkup, nonCurrentAssets, workingCapital, targetRoi
  ]);

  // Economist Model Point variables
  const economistSolutions = useMemo(() => {
    const deltaP = econP1 - econP2;
    const deltaQ = econQ2 - econQ1;
    if (deltaQ === 0) return null;

    const b = deltaP / deltaQ; 
    const a = econP1 + (b * econQ1); 
    const mc = economistMC; 

    // MR = MC => a - 2bQ = MC => Q_opt = (a - MC) / 2b
    const qOpt = (a - mc) / (2 * b);
    const pOpt = a - (b * qOpt); 
    const maxProfitContribution = (pOpt - mc) * qOpt;

    return {
      b: b.toFixed(5),
      a: a.toFixed(2),
      mc: mc.toFixed(2),
      qOpt: qOpt > 0 ? Math.round(qOpt) : 0,
      pOpt: qOpt > 0 ? pOpt.toFixed(2) : a.toFixed(2),
      maxProfitContribution: qOpt > 0 ? maxProfitContribution.toFixed(2) : "0.00"
    };
  }, [econP1, econQ1, econP2, econQ2, economistMC]);

  // Price Elasticity of Demand (PED)
  const pedAnalysis = useMemo(() => {
    if (pedBasePrice === 0 || pedBaseQty === 0) return null;
    const priceChangePct = ((pedNewPrice - pedBasePrice) / pedBasePrice) * 100;
    const qtyChangePct = ((pedNewQty - pedBaseQty) / pedBaseQty) * 100;
    if (priceChangePct === 0) return null;

    const rawPed = qtyChangePct / priceChangePct;
    const pedVal = Math.abs(rawPed);
    const isElastic = pedVal > 1;

    return {
      priceChangePct: priceChangePct.toFixed(1),
      qtyChangePct: qtyChangePct.toFixed(1),
      rawPed: rawPed.toFixed(2),
      pedVal: pedVal.toFixed(2),
      isElastic,
      verdict: isElastic
        ? "Elastic (highly responsive). A price reduction will increase total revenue."
        : "Inelastic (low sensitivity). A price increase will expand total revenue."
    };
  }, [pedBasePrice, pedNewPrice, pedBaseQty, pedNewQty]);

  // Chapter 8 Risk Matrices
  const riskDecisions = useMemo(() => {
    const matrix = {
      Small: { cold: payoffSmallCold, warm: payoffSmallWarm, hot: payoffSmallHot },
      Medium: { cold: payoffMedCold, warm: payoffMedWarm, hot: payoffMedHot },
      Large: { cold: payoffLargeCold, warm: payoffLargeWarm, hot: payoffLargeHot }
    };

    // Maximax (Risky seeker)
    const maxPayoffs = {
      Small: Math.max(matrix.Small.cold, matrix.Small.warm, matrix.Small.hot),
      Medium: Math.max(matrix.Medium.cold, matrix.Medium.warm, matrix.Medium.hot),
      Large: Math.max(matrix.Large.cold, matrix.Large.warm, matrix.Large.hot)
    };
    let maximaxDecision = 'Small';
    if (maxPayoffs.Medium > maxPayoffs[maximaxDecision]) maximaxDecision = 'Medium';
    if (maxPayoffs.Large > maxPayoffs[maximaxDecision]) maximaxDecision = 'Large';

    // Maximin (Pessimist)
    const minPayoffs = {
      Small: Math.min(matrix.Small.cold, matrix.Small.warm, matrix.Small.hot),
      Medium: Math.min(matrix.Medium.cold, matrix.Medium.warm, matrix.Medium.hot),
      Large: Math.min(matrix.Large.cold, matrix.Large.warm, matrix.Large.hot)
    };
    let maximinDecision = 'Small';
    if (minPayoffs.Medium > minPayoffs[maximinDecision]) maximinDecision = 'Medium';
    if (minPayoffs.Large > minPayoffs[maximinDecision]) maximinDecision = 'Large';

    // Minimax Regret
    const bestCold = Math.max(matrix.Small.cold, matrix.Medium.cold, matrix.Large.cold);
    const bestWarm = Math.max(matrix.Small.warm, matrix.Medium.warm, matrix.Large.warm);
    const bestHot = Math.max(matrix.Small.hot, matrix.Medium.hot, matrix.Large.hot);

    const regret = {
      Small: {
        cold: bestCold - matrix.Small.cold,
        warm: bestWarm - matrix.Small.warm,
        hot: bestHot - matrix.Small.hot
      },
      Medium: {
        cold: bestCold - matrix.Medium.cold,
        warm: bestWarm - matrix.Medium.warm,
        hot: bestHot - matrix.Medium.hot
      },
      Large: {
        cold: bestCold - matrix.Large.cold,
        warm: bestWarm - matrix.Large.warm,
        hot: bestHot - matrix.Large.hot
      }
    };

    const maxRegrets = {
      Small: Math.max(regret.Small.cold, regret.Small.warm, regret.Small.hot),
      Medium: Math.max(regret.Medium.cold, regret.Medium.warm, regret.Medium.hot),
      Large: Math.max(regret.Large.cold, regret.Large.warm, regret.Large.hot)
    };

    let minimaxRegretDecision = 'Small';
    if (maxRegrets.Medium < maxRegrets[minimaxRegretDecision]) minimaxRegretDecision = 'Medium';
    if (maxRegrets.Large < maxRegrets[minimaxRegretDecision]) minimaxRegretDecision = 'Large';

    // Expected Value
    const pC = probCold / 100;
    const pW = probWarm / 100;
    const pH = probHot / 100;

    const evs = {
      Small: matrix.Small.cold * pC + matrix.Small.warm * pW + matrix.Small.hot * pH,
      Medium: matrix.Medium.cold * pC + matrix.Medium.warm * pW + matrix.Medium.hot * pH,
      Large: matrix.Large.cold * pC + matrix.Large.warm * pW + matrix.Large.hot * pH
    };

    let maxEvDecision = 'Small';
    if (evs.Medium > evs[maxEvDecision]) maxEvDecision = 'Medium';
    if (evs.Large > evs[maxEvDecision]) maxEvDecision = 'Large';

    // EVPI
    const evWithPI = bestCold * pC + bestWarm * pW + bestHot * pH;
    const evpiValue = evWithPI - evs[maxEvDecision];

    return {
      maxPayoffs,
      maximaxDecision,
      minPayoffs,
      maximinDecision,
      regret,
      maxRegrets,
      minimaxRegretDecision,
      bestCold,
      bestWarm,
      bestHot,
      evs,
      maxEvDecision,
      evWithPI,
      evpiValue
    };
  }, [
    payoffSmallCold, payoffSmallWarm, payoffSmallHot,
    payoffMedCold, payoffMedWarm, payoffMedHot,
    payoffLargeCold, payoffLargeWarm, payoffLargeHot,
    probCold, probWarm, probHot
  ]);

  // Sensitivity Calculations
  const sensitivityAnalysis = useMemo(() => {
    const profit = sensitiveRevenue - sensitiveVarCost - sensitiveFixedCost;
    const revSensitivity = sensitiveRevenue !== 0 ? (profit / sensitiveRevenue) * 100 : 0;
    const varSensitivity = sensitiveVarCost !== 0 ? (profit / sensitiveVarCost) * 100 : 0;
    const fixedSensitivity = sensitiveFixedCost !== 0 ? (profit / sensitiveFixedCost) * 100 : 0;

    return {
      profit,
      revSensitivity: revSensitivity.toFixed(1),
      varSensitivity: varSensitivity.toFixed(1),
      fixedSensitivity: fixedSensitivity.toFixed(1)
    };
  }, [sensitiveRevenue, sensitiveVarCost, sensitiveFixedCost]);

  // Decision Tree Calculations
  const decisionTreeCalculations = useMemo(() => {
    const pSuccess = dtProbSuccess / 100;
    const pFailure = 1 - pSuccess;

    const evProductA = (dtA_success * pSuccess) + (dtA_failure * pFailure);
    const evProductB = (dtB_success * pSuccess) + (dtB_failure * pFailure);

    const optimalChoice = evProductA > evProductB ? 'Product A' : 'Product B';
    const optimalEV = Math.max(evProductA, evProductB);

    return {
      evProductA,
      evProductB,
      pSuccess,
      pFailure,
      optimalChoice,
      optimalEV
    };
  }, [dtProbSuccess, dtA_success, dtA_failure, dtB_success, dtB_failure]);

  // Chapter 9 Budgeting Calculations
  const flexedBudgetResults = useMemo(() => {
    const fixedRev = budgetUnits * fixedUnitRevenue;
    const fixedVar = budgetUnits * fixedUnitVarCost;
    const fixedProfit = fixedRev - fixedVar - fixedBudgetOverhead;

    const flexedRev = actualUnits * fixedUnitRevenue;
    const flexedVar = actualUnits * fixedUnitVarCost;
    const flexedProfit = flexedRev - flexedVar - fixedBudgetOverhead;

    return {
      fixedRev,
      fixedVar,
      fixedProfit,
      flexedRev,
      flexedVar,
      flexedProfit
    };
  }, [budgetUnits, actualUnits, fixedUnitRevenue, fixedUnitVarCost, fixedBudgetOverhead]);

  // Chapter 10 Analytical Techniques: Learning Curve
  const learningCalculations = useMemo(() => {
    const lr = learnRatePct / 100;
    const b = Math.log(lr) / Math.log(2); 
    
    const avgTimeX = timeUnit1 * Math.pow(cumulativeQtyX, b);
    const totalTimeX = avgTimeX * cumulativeQtyX;

    const prevQty = cumulativeQtyX - 1;
    let totalTimePrev = 0;
    if (prevQty > 0) {
      const avgTimePrev = timeUnit1 * Math.pow(prevQty, b);
      totalTimePrev = avgTimePrev * prevQty;
    }
    const incrementalX = totalTimeX - totalTimePrev;

    const steps = [1, 2, 4, 8, 16, 32, 64].filter(v => v <= cumulativeQtyX || v <= 16);
    const progressTable = steps.map(v => {
      const avg = timeUnit1 * Math.pow(v, b);
      return {
        qty: v,
        avg: avg.toFixed(1),
        total: (avg * v).toFixed(1)
      };
    });

    return {
      b: b.toFixed(5),
      avgTimeX: avgTimeX.toFixed(2),
      totalTimeX: totalTimeX.toFixed(1),
      incrementalX: incrementalX.toFixed(1),
      progressTable
    };
  }, [timeUnit1, learnRatePct, cumulativeQtyX]);

  // High-Low Method Calculations
  const highLowSolutions = useMemo(() => {
    const deltaV = highVolume - lowVolume;
    const deltaC = highCost - lowCost;
    if (deltaV === 0) return null;

    const varCostPerUnit = deltaC / deltaV; 
    const fixedCosts = highCost - (varCostPerUnit * highVolume); 

    return {
      varCostPerUnit: varCostPerUnit.toFixed(2),
      fixedCosts: fixedCosts.toFixed(0)
    };
  }, [highVolume, highCost, lowVolume, lowCost]);

  // High-Precision Linear Regression & Correlation Calculator
  const regressionResults = useMemo(() => {
    const data = [
      { x: regPoint1X, y: regPoint1Y },
      { x: regPoint2X, y: regPoint2Y },
      { x: regPoint3X, y: regPoint3Y },
      { x: regPoint4X, y: regPoint4Y },
      { x: regPoint5X, y: regPoint5Y },
    ];

    const n = data.length;
    const sumX = data.reduce((acc, curr) => acc + curr.x, 0);
    const sumY = data.reduce((acc, curr) => acc + curr.y, 0);
    const sumXY = data.reduce((acc, curr) => acc + (curr.x * curr.y), 0);
    const sumX2 = data.reduce((acc, curr) => acc + (curr.x * curr.x), 0);
    const sumY2 = data.reduce((acc, curr) => acc + (curr.y * curr.y), 0);

    const numB = (n * sumXY) - (sumX * sumY);
    const denB = (n * sumX2) - (sumX * sumX);
    if (denB === 0) return null;

    const b = numB / denB;
    const a = (sumY / n) - (b * (sumX / n));

